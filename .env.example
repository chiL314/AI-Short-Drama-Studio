# ===================== 大模型API配置 =====================
# 请在此处填写您的API密钥（不要提交到Git）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DEEPSEEK_MODEL=qwen3.5-flash

# ===================== 视频生成API配置（即梦Seedance） =====================
SEEDANCE_API_KEY=ark-your-seedance-api-key-here
SEEDANCE_API_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
SEEDANCE_MODEL=doubao-seedance-1-0-pro-250528

# ===================== TTS配音配置 =====================
# TTS服务商（aliyun/xunfei/azure）
TTS_PROVIDER=aliyun

# 阿里云TTS（如果使用阿里云）
TTS_ALIYUN_APPKEY=your-aliyun-tts-appkey
TTS_ALIYUN_TOKEN=your-aliyun-tts-token
